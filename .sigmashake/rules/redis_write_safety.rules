# redis_write_safety.rules
# Technology: redis | Capability: write

rule redis-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_redis_PATTERN"
  MESSAGE "Blocked an unsafe pattern in redis. Use the recommended best practices for 2025/2026."
}

rule redis-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_redis_API"
  MESSAGE "You are using an outdated API for redis. Please upgrade to the newer API."
}
